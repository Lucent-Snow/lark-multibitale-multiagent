# =============================================================================
# Feishu Base Multi-Agent Network — Configuration
# =============================================================================
# Copy to config.yaml and fill in values.
# Base token is NOT stored here — pass it via CLI or frontend per project.
# =============================================================================

llm:
  # Volcengine ARK — https://console.volcengine.com/ark
  api_key: "ark-xxx"
  endpoint_id: "ep-xxx"

bot:
  # One Feishu Open Platform app (open.feishu.cn)
  # Required scopes: bitable:app
  app_id: "cli_xxx"
  app_secret: "xxx"
